\mode<presentation>

\definecolor{lscgreen}{RGB}{ 220, 220 ,220}
\definecolor{lscText}{RGB}{1, 146, 225}
\definecolor{lscgreenFonte}{RGB}{219, 36, 25}

\definecolor{lscblue}{RGB}{0	,102	,153}

\definecolor{lscwhite}{RGB}{255,255,255}
%Sumário ou Roteiro 
\setbeamercolor{structure}{fg=lscgreenFonte}

\setbeamercolor{palette primary}{fg=lscText,bg=lscgreen!70}
\setbeamercolor{palette secondary}{fg=lscText,bg=lscgreen!80}
\setbeamercolor{palette tertiary}{fg=lscText,bg=lscgreen!90}
\setbeamercolor{palette quaternary}{fg=lscwhite,bg=lscblue}

\setbeamercolor{titlelike}{parent=palette quaternary}

\setbeamercolor{block title}{fg=lscwhite,bg=lscText}
\setbeamercolor{block title alerted}{use=alerted text,fg=black,bg=alerted text.fg!25!bg}
\setbeamercolor{block title example}{use=example text,fg=black,bg=example text.fg!15!bg}

\setbeamercolor{block body}{parent=normal text,use=block title,bg=block title.bg!25!bg}
\setbeamercolor{block body alerted}{parent=normal text,use=block title alerted,bg=block title alerted.bg!25!bg}
\setbeamercolor{block body example}{parent=normal text,use=block title example,bg=block title example.bg!25!bg}

  
\setbeamercolor{palette sidebar primary}{fg=lscwhite}
\setbeamercolor{palette sidebar secondary}{fg=lscwhite!75}
\setbeamercolor{palette sidebar tertiary}{fg=lscwhite!75}
\setbeamercolor{palette sidebar quaternary}{fg=lscwhite}

\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

\mode
<all>
